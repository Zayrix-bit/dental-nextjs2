# Resend API Key (Get yours from https://resend.com)
RESEND_API_KEY=your_api_key_here
# Base URL for the application (e.g., https://your-domain.vercel.app)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Multi-Clinic Config ──
# Clinic key for multi-clinic support. Available options:
#   default       → DentalCare (New York)
#   smile-studio  → Smile Studio (Los Angeles)
# To add a new clinic, create a config file in src/config/clinics/ and register it in src/config/index.js
NEXT_PUBLIC_CLINIC_KEY=default
